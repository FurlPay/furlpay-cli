{
    "$schema":  "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name":  "io.github.FurlPay/furlpay-cli",
    "description":  "Stablecoin payments, swaps, stock orders, market data, travel booking, yield and card controls.",
    "repository":  {
                       "url":  "https://github.com/FurlPay/furlpay-cli",
                       "source":  "github"
                   },
    "version":  "0.2.2",
    "packages":  [
                     {
                         "registryType":  "npm",
                         "identifier":  "@furlpay/cli",
                         "version":  "0.2.2",
                         "runtimeHint":  "npx",
                         "transport":  {
                                           "type":  "stdio"
                                       },
                         "packageArguments":  [
                                                  {
                                                      "type":  "positional",
                                                      "value":  "mcp",
                                                      "description":  "Start the CLI in MCP server mode"
                                                  }
                                              ]
                     }
                 ]
}